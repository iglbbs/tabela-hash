#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define TAMANHO_TABELA 10
#define MAX_PALAVRA 100
#define MAX_DEFINICAO 300

typedef struct No {
    char palavra[MAX_PALAVRA];
    char definicao[MAX_DEFINICAO];
    struct No *proximo;
} No;

No *tabela[TAMANHO_TABELA];
int total_elementos = 0;

int funcao_hash(char *palavra) {
    int soma = 0;
    int i = 0;
    while (palavra[i] != '\0') {
        soma = soma + palavra[i];
        i++;
    }
    return soma % TAMANHO_TABELA;
}

void inicializar_tabela() {
    int i;
    for (i = 0; i < TAMANHO_TABELA; i++) {
        tabela[i] = NULL;
    }
}
void inserir(char *palavra, char *definicao) {
    int indice = funcao_hash(palavra);

    No *aux = tabela[indice];
    while (aux != NULL) {
        if (strcmp(aux->palavra, palavra) == 0) {
            printf("\n[!] Palavra '%s' ja existe! Atualizando definicao...\n", palavra);
            strcpy(aux->definicao, definicao);
            return;
        }
        aux = aux->proximo;
    }

    No *novo = (No*) malloc(sizeof(No));
    if (novo == NULL) {
        printf("\n[ERRO] Falha ao alocar memoria!\n");
        return;
    }

    strcpy(novo->palavra, palavra);
    strcpy(novo->definicao, definicao);
    novo->proximo = tabela[indice];
    tabela[indice] = novo;

    total_elementos++;
    printf("\n[OK] Palavra '%s' inserida no indice %d!\n", palavra, indice);
}

void buscar(char *palavra) {
    int indice = funcao_hash(palavra);
    No *aux = tabela[indice];

    printf("\n[Busca] Procurando '%s' no indice %d...\n", palavra, indice);

    while (aux != NULL) {
        if (strcmp(aux->palavra, palavra) == 0) {
            printf("----------------------------------\n");
            printf("Palavra   : %s\n", aux->palavra);
            printf("Definicao : %s\n", aux->definicao);
            printf("----------------------------------\n");
            return;
        }
        aux = aux->proximo;
    }

    printf("[!] Palavra '%s' nao encontrada!\n", palavra);
}

void remover(char *palavra) {
    int indice = funcao_hash(palavra);
    No *atual = tabela[indice];
    No *anterior = NULL;

    while (atual != NULL) {
        if (strcmp(atual->palavra, palavra) == 0) {
            if (anterior == NULL) {
                tabela[indice] = atual->proximo;
            } else {
                anterior->proximo = atual->proximo;
            }
            free(atual);
            total_elementos--;
            printf("\n[OK] Palavra '%s' removida com sucesso!\n", palavra);
            return;
        }
        anterior = atual;
        atual = atual->proximo;
    }

    printf("\n[!] Palavra '%s' nao encontrada para remover!\n", palavra);
}

void exibir_tabela() {
    int i;
    printf("\n========== TABELA HASH ==========\n");

    for (i = 0; i < TAMANHO_TABELA; i++) {
        printf("Indice [%2d]: ", i);

        if (tabela[i] == NULL) {
            printf("(vazio)\n");
        } else {
            No *aux = tabela[i];
            while (aux != NULL) {
                printf("[%s] ", aux->palavra);
                if (aux->proximo != NULL) {
                    printf(" -> ");
                }
                aux = aux->proximo;
            }
            printf("\n");
        }
    }

    printf("=================================\n");
}

void exibir_estatisticas() {
    int i;
    int colisoes = 0;
    int maior_lista = 0;
    int posicoes_usadas = 0;

    for (i = 0; i < TAMANHO_TABELA; i++) {
        if (tabela[i] != NULL) {
            posicoes_usadas++;

            int tamanho_lista = 0;
            No *aux = tabela[i];
            while (aux != NULL) {
                tamanho_lista++;
                aux = aux->proximo;
            }

            if (tamanho_lista > 1) {
                colisoes += tamanho_lista - 1;
            }

            if (tamanho_lista > maior_lista) {
                maior_lista = tamanho_lista;
            }
        }
    }

    float fator_carga = (float) total_elementos / TAMANHO_TABELA;

    printf("\n========== ESTATISTICAS ==========\n");
    printf("Tamanho da tabela     : %d\n", TAMANHO_TABELA);
    printf("Total de elementos    : %d\n", total_elementos);
    printf("Posicoes usadas       : %d\n", posicoes_usadas);
    printf("Posicoes vazias       : %d\n", TAMANHO_TABELA - posicoes_usadas);
    printf("Colisoes              : %d\n", colisoes);
    printf("Fator de carga        : %.2f\n", fator_carga);
    printf("Maior lista encadeada : %d elemento(s)\n", maior_lista);
    printf("==================================\n");
}
void liberar_tabela() {
    int i;
    for (i = 0; i < TAMANHO_TABELA; i++) {
        No *atual = tabela[i];
        while (atual != NULL) {
            No *proximo = atual->proximo;
            free(atual);
            atual = proximo;
        }
        tabela[i] = NULL;
    }
}

void limpar_buffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

int main() {
    int opcao;
    char palavra[MAX_PALAVRA];
    char definicao[MAX_DEFINICAO];

    inicializar_tabela();

    printf("=========================================\n");
    printf("  DICIONARIO COM TABELA HASH EM C\n");
    printf("  Trabalho de Estrutura de Dados\n");
    printf("=========================================\n");

    do {
        printf("\n---------- MENU ----------\n");
        printf("1 - Inserir palavra\n");
        printf("2 - Buscar palavra\n");
        printf("3 - Remover palavra\n");
        printf("4 - Mostrar tabela\n");
        printf("5 - Mostrar estatisticas\n");
        printf("0 - Sair\n");
        printf("--------------------------\n");
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);
        limpar_buffer();

        switch (opcao) {

            case 1:
                printf("\nDigite a palavra: ");
                fgets(palavra, MAX_PALAVRA, stdin);
                palavra[strcspn(palavra, "\n")] = '\0';

                printf("Digite a definicao: ");
                fgets(definicao, MAX_DEFINICAO, stdin);
                definicao[strcspn(definicao, "\n")] = '\0';

                inserir(palavra, definicao);
                break;

            case 2:
                printf("\nDigite a palavra a buscar: ");
                fgets(palavra, MAX_PALAVRA, stdin);
                palavra[strcspn(palavra, "\n")] = '\0';

                buscar(palavra);
                break;

            case 3:
                printf("\nDigite a palavra a remover: ");
                fgets(palavra, MAX_PALAVRA, stdin);
                palavra[strcspn(palavra, "\n")] = '\0';

                remover(palavra);
                break;

            case 4:
                exibir_tabela();
                break;

            case 5:
                exibir_estatisticas();
                break;

            case 0:
                printf("\nEncerrando programa...\n");
                break;

            default:
                printf("\n[!] Opcao invalida! Tente novamente.\n");
                break;
        }

    } while (opcao != 0);

    liberar_tabela();

    printf("Memoria liberada. Ate logo!\n");
    return 0;
}
